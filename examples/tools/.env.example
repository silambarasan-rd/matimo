# OpenAI API Key (required for LangChain agent to work)
# Get your key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-api-key-here

# Gmail Example Configuration
# Get your token from: https://developers.google.com/oauthplayground
# GMAIL_ACCESS_TOKEN=<your-access-token-here>
# TEST_EMAIL=<your-email@gmail.com>

# Slack Example Configuration
# Get your token from: https://api.slack.com/apps
# IMPORTANT: Replace C1234567890 with a REAL channel ID where your bot is added
# Find channel ID: Right-click channel > Copy link > Extract ID from URL (e.g., C1234567890)
# IMPORTANT: Replace U1234567890 with a REAL user ID for fallback DMs
# Find user ID: Right-click user > Copy link > Extract ID from URL (e.g., U1234567890)
# SLACK_BOT_TOKEN=xoxb-your-token-here
# SLACK_CHANNEL_ID=C1234567890
# SLACK_USER_ID=U1234567890
# Postgres Example Configuration
# CHOOSE ONE of the two authentication methods below:

# METHOD 1: Connection String (Recommended)
# Uncomment and set your full Postgres connection string
# MATIMO_POSTGRES_URL=postgresql://user:password@localhost:5432/mydatabase

# METHOD 2: Separate Environment Variables
# Uncomment and set these individually if not using connection string
# MATIMO_POSTGRES_HOST=localhost
# MATIMO_POSTGRES_PORT=5432
# MATIMO_POSTGRES_USER=postgres
# MATIMO_POSTGRES_PASSWORD=your-password
# MATIMO_POSTGRES_DB=mydatabase

# SQL Auto-Approval (optional)
# Set to 'true' to auto-approve SQL queries without prompting
# MATIMO_SQL_AUTO_APPROVE=false

# GITHUB_TOKEN=Your_GitHub_token_here

# MATIMO_HUBSPOT_API_KEY=Your_HubSpot_API_key_here

# NOTION_API_KEY=Your_Notion_API_key_here

# MAILCHIMP_API_KEY=Your_Mailchimp_API_key_here

# TWILIO_ACCOUNT_SID=Your_Twilio_Account_SID_here
# TWILIO_AUTH_TOKEN=Your_Twilio_Auth_Token_here
# TWILIO_FROM_NUMBER=Your_Twilio_From_Number_here
# TWILIO_TO_NUMBER=Your_Twilio_To_Number_here